---
interface Props {
  title?: string;
}
const { title = "Maker's Pegboard" } = Astro.props;
import { ClientRouter } from "astro:transitions";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <div class="pegboard-container">
      <!-- 顶部导航：模拟工业铝型材或标签栏 -->
      <header class="industrial-header">
        <div class="status-light"></div>
        <nav>
          <span class="brand">WORKSHOP_OS v1.0</span>
          <div class="nav-links">
            <a href="#">INVENTORY</a>
            <a href="#">LAB_NOTES</a>
          </div>
        </nav>
      </header>

      <main class="workbench">
        <slot />
      </main>

      <footer class="industrial-footer">
        <div class="coordinates">LAT: 31.2304 / LONG: 121.4737</div>
        <div class="system-time">
          BUILD_TIME: {new Date().toLocaleDateString()}
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --gap: 44px; /* 定义统一的孔距步进 */
    --hole-size: 6px;
    --board-bg: #e0e0e0; /* 工业灰或木色 #d2b48c */
    --hole-color: #bcbcbc;
    --accent: #ff5722; /* 创客常用的橙色 */
    --label-bg: #1a1a1a;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100vh;
    background-color: #222;
    display: flex;
    justify-content: center;
    align-items: center;
    font-family: "JetBrains Mono", "Courier New", monospace;
  }

  .pegboard-container {
    display: flex;
    flex-direction: column;
    /* 确保容器占满全屏，这样内部的 flex 才能生效 */
    width: 100vw;
    height: 100vh;
    overflow: hidden;
  }

  /* 顶部工业感 Header */
  .industrial-header {
    background: #333;
    color: #eee;
    padding: 10px 20px;
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .status-light {
    width: 12px;
    height: 12px;
    background: #4caf50;
    border-radius: 50%;
    box-shadow: 0 0 10px #4caf50;
    animation: pulse 2s infinite;
  }

  .nav-links a {
    color: #999;
    text-decoration: none;
    margin-left: 20px;
    font-size: 0.8rem;
  }
  .nav-links a:hover {
    color: var(--accent);
  }

  .workbench {
    flex: 1;
    padding: 20px;
    display: flex;
    justify-content: center;
    /* 修改点：align-items 从 flex-start 改为 stretch */
    /* 这样子元素（Pegboard 或 giant-card-container）默认高度会撑满 workbench */
    align-items: stretch;
    overflow: hidden;
  }

  .industrial-footer {
    background: #222;
    color: #666;
    font-size: 10px;
    padding: 5px 20px;
    display: flex;
    justify-content: space-between;
  }

  @keyframes pulse {
    0% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
    100% {
      opacity: 1;
    }
  }

  /* 移动端适配 */
  @media (max-width: 1024px) {
    .pegboard-container {
      aspect-ratio: auto;
      height: 100vh;
      width: 100vw;
      border: none;
    }
  }
</style>
