---
// src/layouts/Layout.astro
interface Props {
  title?: string;
}
const { title = "Maker's Pegboard" } = Astro.props;
import { ClientRouter } from "astro:transitions";
import Pegboard from "../components/Pegboard.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <div class="pegboard-container">
      <!-- 顶部导航：模拟工业铝型材或标签栏 -->
      <header class="industrial-header">
        <nav>
          <span class="brand">
            Maker Grid:/#<span class="cursor">|</span>
          </span>
          <div class="nav-links">
            <a href="#">#</a>
            <a href="#">#</a>
          </div>
        </nav>
      </header>

      <main class="workbench">
        <Pegboard>
          <slot />
        </Pegboard>
      </main>

      <footer class="industrial-footer">
        <div class="coordinates">LAT: 31.2304 / LONG: 121.4737</div>
        <div class="system-time">
          BUILD_TIME: {new Date().toLocaleDateString()}
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;700;800&display=swap");

  :root {
    --gap: clamp(30px, 4cqw, 44px); /* 定义统一的孔距步进 */
    --hole-size: calc(var(--gap) * 0.1); /* 孔径占孔距的10% */
    --board-bg: #e0e0e0; /* 工业灰或木色 #d2b48c */
    --hole-color: #bcbcbc;

    /* 核心配色方案 */
    --accent: #ff5722; /* 国际橘 - 警示/行动点 */
    --accent-glow: rgba(255, 87, 34, 0.4);
    --bg-dark: #121212; /* 深黑色背景 */
    --label-bg: #1a1a1a; /* 标签背景 */
    --tag: white; /* 标签文字颜色 */
    --panel-bg: #1e1e1e; /* 面板背景 */
    --text-main: #e0e0e0; /* 主文本颜色 */
    --text-dim: #666666; /* 次要/注释文本 */
    --font-mono: "JetBrains Mono", "Fira Code", "Courier New", monospace;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100vh;
    background-color: var(--bg-dark);
    display: flex;
    justify-content: center;
    align-items: center;
    font-family: var(--font-mono);
    color: var(--text-main);
    line-height: 1.5;
  }

  .pegboard-container {
    display: flex;
    flex-direction: column;
    /* 确保容器占满全屏，这样内部的 flex 才能生效 */
    width: 100vw;
    height: 100vh;
  }

  /* 顶部工业感 Header */
  .industrial-header {
    background: var(--panel-bg);
    border-bottom: 1px solid #333;
    padding: 0.8rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .brand {
    font-weight: 800;
    font-size: 1.1rem;
    letter-spacing: -0.5px;
    color: var(--text-main);
    /* 模拟液晶屏或雕刻效果 */
    text-shadow: 0 0 5px rgba(255, 255, 255, 0.1);
  }

  .cursor {
    /* 使用强调色（橙色）让光标醒目 */
    margin-left: 2px;
    font-weight: 800; /* 细一点的竖线更有精致感 */

    /* 动画：每 1 秒循环一次，瞬间切换状态 */
    animation: terminal-blink 2s steps(2, start) infinite;
  }

  @keyframes terminal-blink {
    to {
      opacity: 0;
    }
  }

  /* 增加一个小交互：鼠标悬停在 Header 上时，光标进入“高频输入”状态 */
  .industrial-header:hover .cursor {
    animation-duration: 0.4s;
  }

  .nav-links a {
    color: var(--text-dim);
    text-decoration: none;
    margin-left: 25px;
    font-size: 0.85rem;
    font-weight: 400;
    text-transform: uppercase; /* 强制大写增加工业感 */
    letter-spacing: 1px;
    transition: all 0.2s ease;
    position: relative;
  }

  .nav-links a:hover {
    color: var(--accent);
  }

  .nav-links a:hover::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent-glow);
  }

  .workbench {
    container-type: inline-size;
    flex: 1;
    padding: 20px;
    display: flex;
    justify-content: center;
    /* 修改点：align-items 从 flex-start 改为 stretch */
    /* 这样子元素（Pegboard 或 giant-card-container）默认高度会撑满 workbench */
    align-items: stretch;
    overflow: hidden;
  }

  .industrial-footer {
    background: var(--bg-dark);
    border-top: 1px solid #282828;
    color: var(--text-dim);
    font-size: 11px;
    padding: 8px 20px;
    display: flex;
    justify-content: space-between;
    letter-spacing: 0.5px;
  }

  .coordinates,
  .system-time {
    /* 模拟命令行输出 */
    font-family: var(--font-mono);
    opacity: 0.8;
  }

  /* 移动端适配 */
  @media (max-width: 1024px) {
    .pegboard-container {
      aspect-ratio: auto;
      height: 100vh;
      width: 100vw;
      border: none;
    }
  }
</style>
