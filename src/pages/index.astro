---
// src/pages/index.astro
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Hook from "../components/Hook.astro";
import Card from "../components/Card.astro";
import Tool from "../components/Tool.astro";


import pidTuner from "../assets/pid-tuner.svg";
import arthorizon from "../assets/artificial-horizon.svg";
import caliper from "../assets/caliper.png";
import calculator from "../assets/calculator.svg";

const WIDGET_MAP = {
  pid: { src: pidTuner.src, alt: "PID Tuner" },
  attitude: { src: arthorizon.src, alt: "Artificial Horizon" },
  caliper: { src: caliper.src, alt: "Caliper" },
  calculator: { src: calculator.src, alt: "Calculator" },
};

const allPosts = await getCollection("posts");
const allTools = await getCollection("tools");
---

<Layout title="My Workshop OS">  
  <!-- 渲染所有卡片 (Posts) -->
  {
    allPosts.map((post) => (
      <Hook
        x={post.data.x}
        y={post.data.y}
        cols={post.data.cols}
        rows={post.data.rows}
      >
        
          <Card title={post.data.title} id={post.id}>
            <div class="post-preview">
              {/* Astro 5 中 post.body 已被弃用，建议使用简短摘要或摘要渲染 */}
              {/* 暂时可以使用 post.data 中的新字段或直接显示 */}
              {post.data.excerpt || "No preview available."}
            </div>            
            <div class="post-meta-footer">
              <time class="post-date">
                <span class="meta-label">DATE:</span>
                {new Date(post.data.date).toLocaleDateString('zh-CN', {
                  year: 'numeric',
                  month: '2-digit',
                  day: '2-digit'
                }).replace(/\//g, '.')}
              </time>
              <a href={`/posts/${post.id}`} class="read-more">DETAILS >></a>
            </div>
          </Card>
        
      </Hook>
    ))
  }    

  <!-- 渲染所有工具 (Tools) -->
  {allTools.map((tool) => {
    // 根据数据中的 widgetType 获取对应的图片素材
    const widgetAsset = WIDGET_MAP[tool.data.widgetType];
    
    return (
      <Hook x={tool.data.x} y={tool.data.y} cols={tool.data.cols} rows={tool.data.rows}>
        <Tool label={tool.data.label}>
          {widgetAsset && (
            <img 
              src={widgetAsset.src} 
              alt={widgetAsset.alt} 
              class="widget-svg" 
            />
          )}
        </Tool>
      </Hook>
    );
  })}

</Layout>

<style>
  .post-preview {
    font-size: 0.85rem;
    line-height: 1.5;
    margin-bottom: 10px;
    color: #444;
  }
  .read-more {
    font-size: 0.7rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: bold;
    display: block;
    margin-top: auto;
  }
  .read-more:hover {
    text-decoration: underline;
  }
  .widget-svg {
    /* 核心属性：撑满父容器但保持比例 */
    width: 100%;
    height: 100%;
    
    /* 关键属性：像背景图一样缩放，确保内容全部显示且不变形 */
    object-fit: contain; 
    
    /* 增加一点点内边距，不让波形图贴死边框 */
    padding: 10px; 
  }

  .post-meta-footer {
    margin-top: auto; /* 推到底部 */
    padding-top: 10px;    
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: left;
  }
  .post-date {
    font-family: var(--font-mono);
    font-size: 10px;
    color: #666;
    letter-spacing: 0.5px;
  }
  .meta-label {
    color: #444;    
  }
</style>