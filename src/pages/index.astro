---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Hook from "../components/Hook.astro";
import Card from "../components/Card.astro";
import Tool from "../components/Tool.astro";
import pidTuner from "../assets/pid-tuner.svg";
const allPosts = await getCollection("posts");
---

<Layout title="My Workshop OS">  
    {
      allPosts.map((post) => (
        <Hook
          x={post.data.x}
          y={post.data.y}
          cols={post.data.cols}
          rows={post.data.rows}
        >
          
            <Card title={post.data.title} id={post.id}>
              <div class="post-preview">
                {/* Astro 5 中 post.body 已被弃用，建议使用简短摘要或摘要渲染 */}
                {/* 暂时可以使用 post.data 中的新字段或直接显示 */}
                abc...
              </div>            
              <a href={`/posts/${post.id}`} class="read-more">DETAILS >></a>
            </Card>
          
        </Hook>
      ))
    }    

    <!-- 挂一个工具组件 (比如一个时钟或状态指示器) -->
    <Hook x={5} y={8} cols={8} rows={5}>
      <Tool label="STABILITY_OSCILLOSCOPE">
        <img 
          src={pidTuner.src} 
          alt="PID Tuner" 
          class="widget-svg"
        />
      </Tool>
    </Hook>

    <!-- 挂另一个工具组件 -->
    <Hook x={14} y={3} cols={2} rows={2}>
      <Tool label="POWER">
        <div style="width:20px; height:20px; background:red; border-radius:50%">
        </div>
      </Tool>
    </Hook>
    
</Layout>

<style>
  .post-preview {
    font-size: 0.85rem;
    line-height: 1.5;
    margin-bottom: 10px;
    color: #444;
  }
  .read-more {
    font-size: 0.7rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: bold;
    display: block;
    margin-top: auto;
  }
  .read-more:hover {
    text-decoration: underline;
  }
  .widget-svg {
    /* 核心属性：撑满父容器但保持比例 */
    width: 100%;
    height: 100%;
    
    /* 关键属性：像背景图一样缩放，确保内容全部显示且不变形 */
    object-fit: contain; 
    
    /* 增加一点点内边距，不让波形图贴死边框 */
    padding: 10px; 
  }
</style>