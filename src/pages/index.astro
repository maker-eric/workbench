---
// src/pages/index.astro
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Hook from "../components/Hook.astro";
import Card from "../components/Card.astro";
import Tool from "../components/Tool.astro";
import NavPlate from "../components/NavPlate.astro";

import "../styles/common.css";

import pidTuner from "../assets/pid-tuner.svg";
import arthorizon from "../assets/artificial-horizon.svg";
import caliper from "../assets/caliper.png";
import calculator from "../assets/calculator.svg";

const WIDGET_MAP = {
  pid: { src: pidTuner.src, alt: "PID Tuner" },
  attitude: { src: arthorizon.src, alt: "Artificial Horizon" },
  caliper: { src: caliper.src, alt: "Caliper" },
  calculator: { src: calculator.src, alt: "Calculator" },
};

const allPosts = await getCollection("posts");
const allTools = await getCollection("tools");
---

<Layout title="My Workshop OS">  
  <!-- 渲染所有卡片 (Posts) -->
  {
    allPosts.map((post) => (
      <Hook
        x={post.data.x}
        y={post.data.y}
        cols={post.data.cols}
        rows={post.data.rows}
        class="post-hook"
      >        
        <Card title={post.data.title} id={post.id}>
          <div class="post-preview">
            {/* Astro 5 中 post.body 已被弃用，建议使用简短摘要或摘要渲染 */}
            {/* 暂时可以使用 post.data 中的新字段或直接显示 */}
            {post.data.excerpt || "No preview available."}
          </div>            
          <div class="post-meta-footer">
            <time class="post-date">
              <span class="meta-label">DATE:</span>
              {new Date(post.data.date).toLocaleDateString('zh-CN', {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit'
              }).replace(/\//g, '.')}
            </time>
            <a href={`posts/${post.id}`} class="read-more">DETAILS >></a>
          </div>
        </Card>        
      </Hook>
    ))
  }    

  <!-- 渲染所有工具 (Tools) -->
  {allTools.map((tool) => {
    // 根据数据中的 widgetType 获取对应的图片素材
    const widgetAsset = WIDGET_MAP[tool.data.widgetType];
    
    return (
      <Hook 
        x={tool.data.x} 
        y={tool.data.y} 
        cols={tool.data.cols} 
        rows={tool.data.rows}
        class="tool-hook"
        >
        <Tool label={tool.data.label}>
          {widgetAsset && (
            <img 
              src={widgetAsset.src} 
              alt={widgetAsset.alt} 
              class="widget-svg" 
            />
          )}
        </Tool>
      </Hook>
    );
  })}

<NavPlate 
  x={1}
  y={1}
  cols={8}
  rows={1}
  class="nav-plate"
  currentPage={1} 
  totalPages={5} 
  baseUrl="/posts" 
    />
</Layout>

<style>
  .post-preview {
    font-size: 0.85rem;
    line-height: 1.5;
    margin-bottom: 10px;
    color: #444;

    display: -webkit-box;
    -webkit-line-clamp: 3;    /* 限制显示 3 行 */
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis; 
    
  }
  .read-more {
    font-size: 0.7rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: bold;
    display: block;
    margin-top: auto;
  }
  .read-more:hover {
    text-decoration: underline;
  }
  .widget-svg {
    /* 核心属性：撑满父容器但保持比例 */
    width: 100%;
    height: 100%;
    
    /* 关键属性：像背景图一样缩放，确保内容全部显示且不变形 */
    object-fit: contain; 
    
    /* 增加一点点内边距，不让波形图贴死边框 */
    padding: 10px; 
  }

  .post-meta-footer {
    margin-top: auto; /* 推到底部 */
    padding-top: 10px;    
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: left;
  }
  .post-date {
    font-family: var(--font-mono);
    font-size: 10px;
    color: #666;
    letter-spacing: 0.5px;
  }
  .meta-label {
    color: #444;    
  }
</style>

<script>
  function autoAlignHooks() {
    // 2. 获取 Pegboard 容器
    const board = document.querySelector('.pegboard') as HTMLElement;
    if (!board) return;

    const boardStyle = window.getComputedStyle(board);
    const gridColsResolved = boardStyle.gridTemplateColumns;
    const colArray = gridColsResolved.trim().split(' ');
    const gap = parseFloat(colArray[0]);    
    console.log(`colArray: ${colArray}, gap: ${gap}`);

    // 3. 计算当前容器实际能容纳的列数 (floor 取整保证对齐孔位)
    const paddingLeft = parseFloat(boardStyle.paddingLeft);
    const paddingRight = parseFloat(boardStyle.paddingRight);
    const totalCols = Math.round((board.clientWidth - paddingLeft - paddingRight) / gap);
    console.log(`Current Grid Columns: ${totalCols}`);

    const paddingTop = parseFloat(boardStyle.paddingTop);
    const paddingBottom = parseFloat(boardStyle.paddingBottom);
    const totalRows = Math.round((board.clientHeight - paddingTop - paddingBottom) / gap);
    console.log(`Current Grid Rows: ${totalRows}`);

    const isTooSmall = totalCols < 13 || totalRows < 13;
    const toolHooks = document.querySelectorAll('.tool-hook') as NodeListOf<HTMLElement>;

    toolHooks.forEach(hook => {
      hook.style.display = isTooSmall ? 'none' : 'flex';
    });
    
    const postHooks = document.querySelectorAll('.post-hook') as NodeListOf<HTMLElement>;
    let visiblePostCount = 0;

    postHooks.forEach((hook, index) => {
    if (isTooSmall) {
      // --- 精简模式逻辑 ---
      if (visiblePostCount < 2) {
        hook.style.display = 'flex';
        
        // 判断是纵向空间不足还是横向空间不足，决定是撑满宽还是撑满高
        if (totalCols < 13) {
           // 一列显示：宽度撑满，y 坐标顺排（防止重叠）
           hook.style.setProperty('--x', '1'); // 居中显示
           hook.style.setProperty('--cols', totalCols.toString());           
           hook.style.setProperty('--y', (visiblePostCount*Math.floor(totalRows/2) + 1).toString());
           hook.style.setProperty('--rows', (Math.floor(totalRows/2)-1).toString());
        } else {
           // 一行显示：高度撑满，x 坐标顺排
           hook.style.setProperty('--y', '1');
           hook.style.setProperty('--cols', (Math.floor(totalCols/2)-1).toString());
           hook.style.setProperty('--rows', totalRows.toString());
           // 假设每个精简文章占 6 列宽度
           hook.style.setProperty('--x', (visiblePostCount * Math.floor(totalCols/2) + 1).toString());
        }
        visiblePostCount++;
      } else {
        // 超过 3 个的隐藏
        hook.style.display = 'none';
      }
    } else {
      // --- 恢复原始布局逻辑 ---
      hook.style.display = 'flex';
      hook.style.setProperty('--x', hook.dataset.origX!);
      hook.style.setProperty('--y', hook.dataset.origY!);
      hook.style.setProperty('--cols', hook.dataset.origCols!);
      hook.style.setProperty('--rows', hook.dataset.origRows!);
    }
  });  
    const navPlate = document.querySelector('.nav-plate') as HTMLElement;
    if (isTooSmall) {
      navPlate.style.setProperty('--x', '1');
      navPlate.style.setProperty('--y', (totalRows - 1).toString());
    } else {
      const startX = totalCols - 8 + 1;
      const startY = totalRows - 2 + 1;
      
      navPlate.style.setProperty('--x', startX.toString());
      navPlate.style.setProperty('--y', startY.toString());
    }

  }    

  // 监听窗口缩放
  window.addEventListener('resize', autoAlignHooks);

  // 监听 Astro 页面加载 (支持 View Transitions)
  document.addEventListener('astro:page-load', autoAlignHooks);
</script>