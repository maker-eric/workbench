---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="404 • Page Not Found"
  description="The page you are looking for does not exist."
  canonical="/404"
  noindex={true}
>
  <div class="not-found">
    <h1>404</h1>
    <p>The requested page could not be found.</p>
    <a href="/workbench/">Return to the board</a>
  </div>
</Layout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    color: var(--text-main);
    gap: 0.75rem;
  }

  .not-found a {
    color: var(--accent);
    text-decoration: none;
  }
</style>
