---
// src/pages/posts/[id].astro
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Card from "../../components/Card.astro";
import Comments from "../../components/Comments.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
// 使用 render() 函数渲染内容
const { Content } = await render(post);
const postDescription =
  post.data.excerpt || "Read this post on Maker's Pegboard.";
const postCanonical = `/posts/${post.id}`;
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  datePublished: post.data.date.toISOString(),
  description: post.data.excerpt,
  author: [
    {
      "@type": "Person",
      name: "Eric",
      url: "https://maker-eric.github.com/about",
    },
  ],
});
---

<Layout
  title={post.data.title}
  description={postDescription}
  canonical={postCanonical}
  type="article"
  articleDate={new Date(post.data.date).toISOString()}
>
  <!-- 1. 复用 Card 组件 -->
  <!-- 2. 传入相同的 id，让 View Transitions 知道它是从刚才那个小卡片变过来的 -->
  <div class="detail-hook">
    <div class="giant-card-container">
      <Card title={post.data.title} id={post.id}>
        <article class="prose">
          <Content />
          <Comments />
        </article>
        <div class="footer-actions">
          <a href="#" onclick="history.back(); return false;">← BACK TO BOARD</a
          >
        </div>
      </Card>
    </div>
  </div>
</Layout>

<style>
  .detail-hook {
    /* 控制放大后卡片的大小 */
    position: absolute;
    top: 0px;
    left: var(--gap);
    right: var(--gap);
    bottom: var(--gap);
    z-index: 100;
    max-width: 1200px;
    display: flex;
    justify-content: center;
    align-items: stretch;
    flex-direction: column;
  }

  .footer-actions {
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px dashed rgba(0, 0, 0, 0.1);
  }

  .footer-actions a {
    color: var(--accent);
    text-decoration: none;
    font-size: 12px;
    font-weight: bold;
    display: inline-block;
    padding: 5px 10px;
    border: 1px solid var(--accent);
    border-radius: 4px;
  }

  .giant-card-container {
    width: 100%;
    max-width: 1000px;
    height: 100%; /* 撑满 detail-hook */
    display: flex;
    flex-direction: column;
  }

  /* 针对文章内容的样式微调 */
  .prose {
    line-height: 1.6;
    flex: 1;
    overflow-y: auto;
    padding-right: 10px; /* 给滚动条留点空间 */
    min-height: 0;
  }
</style>

<script type="application/ld+json" set:html={schema} />
