---
// src/pages/posts/[id].astro
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Card from "../../components/Card.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { id: post.id }, // 使用 id
    props: { post },
  }));
}

const { post } = Astro.props;
// 使用 render() 函数渲染内容
const { Content } = await render(post);
---

<Layout title={post.data.title}>
  <div class="detail-wrapper">
    <!-- 1. 复用 Card 组件 -->
    <!-- 2. 传入相同的 id，让 View Transitions 知道它是从刚才那个小卡片变过来的 -->
    <div class="giant-card-container">
      <Card title={post.data.title} id={post.id}>
        <article class="prose">
          <Content />
        </article>

        <div class="footer-actions">
          <a href="/">← BACK TO BOARD</a>
        </div>
      </Card>
    </div>
  </div>
</Layout>

<style>
  .detail-wrapper {
    width: 100vw;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background: #222; /* 这里可以沿用你工作台的背景色 */
    padding: 40px;
    box-sizing: border-box;
  }

  .giant-card-container {
    /* 控制放大后卡片的大小 */
    width: 100%;
    max-width: 800px;
    height: 80vh;
  }

  .footer-actions {
    margin-top: 20px;
    padding-top: 10px;
    border-top: 1px dashed #ccc;
  }

  .footer-actions a {
    color: var(--accent);
    text-decoration: none;
    font-size: 12px;
    font-weight: bold;
  }

  /* 针对文章内容的样式微调 */
  .prose {
    line-height: 1.6;
  }
</style>
