---
// src/pages/posts/[...page].astro
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Hook from "../components/Hook.astro";
import Card from "../components/Card.astro";
import Tool from "../components/Tool.astro";
import NavPlate from "../components/NavPlate.astro";
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";

import "../styles/common.css";

interface Props {
  page: Page<CollectionEntry<"posts">>; // 显式声明 page 的类型
}

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const posts = await getCollection("posts");

  // 排序：按日期倒序
  const sortedPosts = posts.sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  );

  // 这里的 pageSize 建议设置为 index.astro 预留的卡片坑位数
  // 假设你的 index 设计了 8 个卡片位置
  return paginate(sortedPosts, { pageSize: 6 });
};

const { page } = Astro.props;
import pidTuner from "../assets/pid-tuner.svg";
import arthorizon from "../assets/artificial-horizon.svg";
import caliper from "../assets/caliper.png";
import calculator from "../assets/calculator.svg";

const WIDGET_MAP = {
  pid: { src: pidTuner.src, alt: "PID Tuner" },
  attitude: { src: arthorizon.src, alt: "Artificial Horizon" },
  caliper: { src: caliper.src, alt: "Caliper" },
  calculator: { src: calculator.src, alt: "Calculator" },
};

const allTools = await getCollection("tools");
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout
  title="Pegboard Posts"
  description="Browse Maker's Pegboard posts, experiments, and notes in a compact industrial-style dashboard."
  canonical="/"
>
  <!-- 这里的 class 应该和你 index.astro 里的主容器一致 -->
  {
    page.data.map((post, index) => {
      //   const pos = cardPositions[index]; // 获取预设的网格坐标
      return (
        <Hook x={1} y={1} cols={8} rows={6} class="post-hook">
          <Card title={post.data.title} id={post.id}>
            <div class="post-preview">
              {post.data.excerpt || "No preview available."}
            </div>

            <div class="post-meta-footer">
              <time class="post-date">
                <span class="meta-label">DATE:</span>
                {new Date(post.data.date || post.data.date)
                  .toLocaleDateString("zh-CN", {
                    year: "numeric",
                    month: "2-digit",
                    day: "2-digit",
                  })
                  .replace(/\//g, ".")}
              </time>
              <a href={`${base}/posts/${post.id}`} class="read-more">
                DETAILS &gt;&gt;
              </a>
            </div>
          </Card>
        </Hook>
      );
    })
  }

  <!-- 随机工具渲染 (初始隐藏，由脚本定位) -->
  {
    allTools.map((tool) => {
      const widgetAsset =
        WIDGET_MAP[tool.data.widgetType as keyof typeof WIDGET_MAP];
      return (
        <Hook
          cols={tool.data.cols}
          rows={tool.data.rows}
          class="tool-hook dynamic-tool"
          style="display: none;"
        >
          <Tool label={tool.data.label}>
            {widgetAsset && (
              <img
                src={widgetAsset.src}
                alt={widgetAsset.alt}
                class="widget-svg"
              />
            )}
          </Tool>
        </Hook>
      );
    })
  }

  <!-- 分页条：放在网格底部，使用与 index.astro 一致的位置 -->
  {
    page.lastPage > 1 && (
      <NavPlate
        x={1}
        y={1}
        cols={8}
        rows={1}
        class="nav-plate"
        currentPage={page.currentPage}
        totalPages={page.lastPage}
        baseUrl=""
      />
    )
  }
</Layout>

<style>
  .post-desc {
    font-size: 0.85rem;
    opacity: 0.8;
    line-height: 1.4;
  }
  .post-preview {
    font-size: 0.85rem;
    line-height: 1.5;
    margin-bottom: 10px;
    color: #444;

    display: -webkit-box;
    -webkit-line-clamp: 3; /* 限制显示 3 行 */
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .read-more {
    font-size: 0.7rem;
    color: var(--accent);
    text-decoration: none;
    font-weight: bold;
    display: block;
    margin-top: auto;
  }
  .read-more:hover {
    text-decoration: underline;
  }
  .widget-svg {
    /* 核心属性：撑满父容器但保持比例 */
    width: 100%;
    height: 100%;

    /* 关键属性：像背景图一样缩放，确保内容全部显示且不变形 */
    object-fit: contain;

    /* 增加一点点内边距，不让波形图贴死边框 */
    padding: 10px;
  }
  .post-meta-footer {
    margin-top: auto; /* 推到底部 */
    padding-top: 10px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: left;
  }
  .post-date {
    font-family: var(--font-mono);
    font-size: 10px;
    color: #666;
    letter-spacing: 0.5px;
  }
  .meta-label {
    color: #444;
  }
</style>

<script>
  function autoAlignHooks() {
    // 2. 获取 Pegboard 容器
    const board = document.querySelector(".pegboard") as HTMLElement;
    if (!board) return;

    const boardStyle = window.getComputedStyle(board);
    const gridColsResolved = boardStyle.gridTemplateColumns;
    const colArray = gridColsResolved.trim().split(" ");
    const gap = parseFloat(colArray[0]);
    console.log(`colArray: ${colArray}, gap: ${gap}`);

    // 3. 计算当前容器实际能容纳的列数 (floor 取整保证对齐孔位)
    const paddingLeft = parseFloat(boardStyle.paddingLeft);
    const paddingRight = parseFloat(boardStyle.paddingRight);
    const totalCols = Math.round(
      (board.clientWidth - paddingLeft - paddingRight) / gap,
    );
    console.log(`Current Grid Columns: ${totalCols}`);

    const paddingTop = parseFloat(boardStyle.paddingTop);
    const paddingBottom = parseFloat(boardStyle.paddingBottom);
    const totalRows = Math.round(
      (board.clientHeight - paddingTop - paddingBottom) / gap,
    );
    console.log(`Current Grid Rows: ${totalRows}`);

    const toolHooks = document.querySelectorAll(
      ".tool-hook",
    ) as NodeListOf<HTMLElement>;
    toolHooks.forEach((tool) => (tool.style.display = "none"));

    const postHooks = document.querySelectorAll(
      ".post-hook",
    ) as NodeListOf<HTMLElement>;

    const navPlate = document.querySelector(".nav-plate") as HTMLElement;

    const cardW = 8;
    const cardH = 6;
    const spacing = 1;
    let volumeCount = Math.floor(totalCols / (cardW + spacing));
    if (volumeCount < 1) volumeCount = 1;

    // 2. 检查右侧剩余空间
    // 计算所有卡片占用的总宽度
    const usedWidthByCards = volumeCount * (cardW + spacing);
    const sideW = totalCols - usedWidthByCards; // 右侧剩余的空列数

    // 逻辑开关：是否可以在右侧放入工具和导航
    const canFitSidePanel = volumeCount > 1 && sideW >= 3;

    let lastY = 0;
    postHooks.forEach((hook, index) => {
      // 计算当前卡片所在的行列位置 (Row-major)
      const colIdx = index % volumeCount;
      const rowIdx = Math.floor(index / volumeCount);

      // 计算坐标 (基于 1 开始的 grid 坐标)
      const x = 1 + colIdx * (cardW + spacing);
      const y = 1 + rowIdx * (cardH + spacing);

      hook.style.setProperty("--x", x.toString());
      hook.style.setProperty("--y", y.toString());
      if (volumeCount == 1) {
        hook.style.setProperty("--cols", totalCols.toString());
      } else {
        hook.style.setProperty("--cols", cardW.toString());
      }
      hook.style.setProperty("--rows", cardH.toString());

      // 记录最下方的 y 坐标
      lastY = Math.max(lastY, y + cardH - 1);
    });

    // 4. 布局 NavPlate 和 ToolHooks

    if (canFitSidePanel) {
      // --- 右侧排列模式 ---
      const sideX = usedWidthByCards + 1;
      const navH = 1;

      if (navPlate) {
        // NavPlate：与 PostHooks 下对齐 (y = lastY)
        navPlate.style.setProperty("--x", sideX.toString());
        navPlate.style.setProperty("--y", lastY.toString());
        navPlate.style.setProperty("--cols", sideW.toString());
        navPlate.style.setProperty("--rows", navH.toString());
      }
      // ToolHooks：从顶部开始排列，尝试填入右侧空间
      const randomIndex = Math.floor(Math.random() * toolHooks.length);
      const selectedTool = toolHooks[randomIndex] as HTMLElement;

      const tW = parseInt(selectedTool.dataset.origCols || "4");
      const tH = parseInt(selectedTool.dataset.origRows || "4");
      console.log(`Selected Tool Index: ${randomIndex}, tW: ${tW}, tH: ${tH}`);
      selectedTool.style.display = "flex";
      selectedTool.style.setProperty("--x", sideX.toString());
      selectedTool.style.setProperty("--y", "1"); // 与 PostHooks 上对齐
      selectedTool.style.setProperty("--cols", Math.min(tW, sideW).toString());
      selectedTool.style.setProperty("--rows", tH.toString());
    } else {
      if (navPlate) {
        // --- 底部排列模式 (空间不足时) ---
        const navY = lastY + spacing + 1;
        if (volumeCount == 1) {
          navPlate.style.setProperty("--cols", totalCols.toString());
        } else {
          navPlate.style.setProperty("--cols", cardW.toString());
        }
        navPlate.style.setProperty(
          "--x",
          ((volumeCount - 1) * (cardW + spacing) + 1).toString(),
        );
        navPlate.style.setProperty("--y", navY.toString());
        navPlate.style.setProperty("--rows", "1");
      }
    }
  }

  // 监听窗口缩放
  window.addEventListener("resize", autoAlignHooks);

  // 监听 Astro 页面加载 (支持 View Transitions)
  document.addEventListener("astro:page-load", autoAlignHooks);
</script>
