---
// src/components/NavPlate.astro

interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
  x: number;
  y: number;
  cols?: number;
  rows?: number;
  class?: string;
}

const {
  currentPage,
  totalPages,
  baseUrl,
  x,
  y,
  cols = 8,
  rows = 2,
  class: customClass,
} = Astro.props;

const isFirst = currentPage === 1;
const isLast = currentPage === totalPages;

// 适配 GitHub Pages 路径
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const fullBaseUrl = `${base}${baseUrl}`;
const getUrl = (p: number) => {
  if (p === 1) {
    // 第一页永远是根目录 (考虑到 GitHub Pages 的 base 路径)
    return base === "" ? "/" : `${base}/`;
  }
  // 其他页码为 /2, /3 等
  return `${base}/${p}`;
};

const prevUrl = getUrl(currentPage - 1);
const nextUrl = getUrl(currentPage + 1);
---

<div
  class:list={["nav-plate", customClass]}
  data-layout="nav-plate"
  data-orig-x={x}
  data-orig-y={y}
  data-orig-cols={cols}
  data-orig-rows={rows}
  style={`--x: ${x}; --y: ${y}; --cols: ${cols}; --rows: ${rows};`}
>
  <!-- 左上角主钉子 -->
  <div class="peg-pin pin-tl"></div>
  <!-- 右下角加固钉子 -->
  <div class="peg-pin pin-br"></div>

  <div class="plate-body acrylic-panel">
    <div class="nav-content">
      <!-- 上一页 -->
      <a
        href={prevUrl}
        class:list={["nav-btn", { disabled: isFirst }]}
        aria-label="Previous Page"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg
        >
      </a>

      <!-- 页码显示 -->
      <div class="page-info">
        <span class="current">{currentPage}</span>
        <span class="divider">/</span>
        <span class="total">{totalPages}</span>
      </div>

      <!-- 下一页 -->
      <a
        href={nextUrl}
        class:list={["nav-btn", { disabled: isLast }]}
        aria-label="Next Page"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg
        >
      </a>
    </div>
  </div>

  <style>
    .nav-plate {
      grid-column: var(--x) / span var(--cols);
      grid-row: var(--y) / span var(--rows);
      position: relative;
      display: flex;
      padding: 0; /* 铭牌贴合板子 */
      box-sizing: border-box;
      /* 抵消 Pegboard 的默认偏移，让钉子对准孔 */
      margin-top: 0;
    }

    /* 左上角定位 */
    .pin-tl {
      top: 0;
      left: 0;
      transform: translate(-50%, -50%);
    }

    /* 右下角定位 */
    .pin-br {
      bottom: 0;
      right: 0;
      transform: translate(50%, 50%);
    }

    /* 铭牌主体 */
    .plate-body {
      width: 100%;
      height: 100%;

      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      overflow: hidden;
    }
    .nav-content {
      background: var(--accent);
      height: 80%;
      width: 96%; /* 宽度留一点微小边距更精致 */
      border-radius: 8px;
      display: flex;
      justify-content: space-between; /* 按钮分布在两端 */
      align-items: center;
      padding: 0 10px;
      box-sizing: border-box;
      color: white; /* 假设背景是橙色，文字设为白色 */
    }
    /* 翻页按钮 */
    .nav-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255, 255, 255, 0.9);
      text-decoration: none;
      transition: all 0.2s ease;
      width: 32px;
      height: 32px;
      border-radius: 6px;
    }

    .nav-btn:hover:not(.disabled) {
      background: rgba(255, 255, 255, 0.2);
      color: white;
      transform: scale(1.1);
    }

    .nav-btn.disabled {
      opacity: 0.3;
      cursor: not-allowed;
      pointer-events: none;
    }

    /* 页码信息样式 */
    .page-info {
      font-family: "JetBrains Mono", monospace, sans-serif;
      font-weight: 700;
      font-size: 1.1rem;
      display: flex;
      align-items: center;
      gap: 6px;
      letter-spacing: 1px;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
    }

    .divider {
      opacity: 0.6;
      font-weight: 300;
    }

    .total {
      font-size: 0.9rem;
      opacity: 0.8;
    }
  </style>
</div>
