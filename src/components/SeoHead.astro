---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: string;
  articleDate?: string;
  noindex?: boolean;
}

const {
  title = "Maker's Pegboard",
  description = "A compact personal workspace for notes, tools, and experiments built with Astro.",
  image = "/favicon.svg",
  canonical,
  type = "website",
  articleDate,
  noindex = false,
} = Astro.props;

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "") || "";
const resolvedTitle = title.includes("Maker") ? title : `${title} | Maker's Pegboard`;
const resolvedDescription = description;
const normalizePath = (path: string) => {
  const trimmedPath = path.startsWith("/") ? path : `/${path}`;
  return `${basePath}${trimmedPath}`;
};
const resolvedCanonical = canonical
  ? canonical.startsWith("http")
    ? canonical
    : new URL(
        normalizePath(canonical),
        Astro.site ?? "https://maker-eric.github.com",
      ).toString()
  : new URL(
      normalizePath(Astro.url.pathname),
      Astro.site ?? "https://maker-eric.github.com",
    ).toString();

const resolveUrl = (value: string) => {
  if (/^https?:\/\//i.test(value)) {
    return value;
  }

  const normalizedValue = value.startsWith("/") ? value : `/${value}`;
  return new URL(`${basePath}${normalizedValue}`, Astro.site ?? "https://maker-eric.github.com").toString();
};

const resolvedImage = resolveUrl(image);
const ogType = type === "article" ? "article" : "website";
const jsonLd = {
  "@context": "https://schema.org",
  "@type": type === "article" ? "BlogPosting" : "WebSite",
  headline: resolvedTitle,
  name: "Maker's Pegboard",
  description: resolvedDescription,
  url: resolvedCanonical,
  image: resolvedImage,
  ...(articleDate ? { datePublished: articleDate } : {}),
};
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content={resolvedDescription} />
<meta name="theme-color" content="#121212" />
<meta name="robots" content={noindex ? "noindex,nofollow" : "index,follow,max-image-preview:large"} />
<title>{resolvedTitle}</title>
<link rel="canonical" href={resolvedCanonical} />
<link rel="icon" href={resolveUrl("/favicon.svg")} />
<link rel="shortcut icon" href={resolveUrl("/favicon.ico")} />
<meta property="og:type" content={ogType} />
<meta property="og:title" content={resolvedTitle} />
<meta property="og:description" content={resolvedDescription} />
<meta property="og:url" content={resolvedCanonical} />
<meta property="og:image" content={resolvedImage} />
<meta property="og:image:alt" content={resolvedTitle} />
<meta property="og:site_name" content="Maker's Pegboard" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={resolvedTitle} />
<meta name="twitter:description" content={resolvedDescription} />
<meta name="twitter:image" content={resolvedImage} />
{articleDate && <meta property="article:published_time" content={articleDate} />}
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
