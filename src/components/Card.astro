---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<div class="card">
  <header>{title}</header>
  <div class="content">
    <slot />
  </div>
</div>

<style>
  .card {
    background: #fff;
    width: 100%;
    height: 100%;
    border: 1px solid #999;
    box-shadow: 4px 4px 0px rgba(0, 0, 0, 0.2);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  header {
    background: var(--label-bg);
    color: var(--accent);
    padding: 4px 8px;
    font-size: 12px;
    font-weight: bold;
  }
  .content {
    padding: 10px;
    font-size: 14px;
    color: #333;
    overflow: hidden;
  }
</style>
