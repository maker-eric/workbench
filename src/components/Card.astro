---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<div class="card">
  <header>{title}</header>
  <div class="content">
    <slot />
  </div>
</div>

<style>
  .card {
    width: 100%;
    height: 100%;

    display: flex;
    flex-direction: column;
    overflow: hidden;

    /*background: rgba(255, 255, 255, 0.25); /* 白色半透明，0~1可调透明度 */
    backdrop-filter: blur(5px); /* 背景模糊，数值越大越磨砂 */

    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 12px; /* 圆角是亚克力灵魂，不加很难有质感 */

    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.12),
      inset 0 0 0 1px rgba(255, 255, 255, 0.15);
  }
  header {
    margin-top: 16px;
    background: var(--label-bg);
    color: var(--accent);
    padding: 4px 8px;
    font-size: 12px;
    font-weight: bold;
  }
  .content {
    padding: 10px;
    font-size: 14px;
    color: #333;
    background: rgba(255, 255, 255);
    overflow: hidden;
  }
</style>
