---
// src/components/Card.astro
interface Props {
  title: string;
  id?: string; // 增加一个可选的 id，用于 View Transition
}
const { title, id } = Astro.props;
---

<div class="card" transition:name={id}>
  <header>{title}</header>
  <div class="content">
    <slot />
  </div>
</div>

<style>
  .card {
    width: 100%;
    height: 100%;

    display: flex;
    flex-direction: column;
    overflow: hidden;

    /*background: rgba(255, 255, 255, 0.25); /* 白色半透明，0~1可调透明度 */
    backdrop-filter: blur(5px); /* 背景模糊，数值越大越磨砂 */

    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 12px; /* 圆角是亚克力灵魂，不加很难有质感 */

    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.12),
      inset 0 0 0 1px rgba(255, 255, 255, 0.15);
  }
  header {
    margin-top: 16px;
    background: var(--accent);
    color: var(--tag);
    /* color: var(--accent); */
    padding: 4px 10px;
    font-size: 12px;
    font-weight: bold;
    justify-content: space-between;
    box-shadow: 1px 1px 3px rgba(0, 0, 0, 0.3);
  }

  .content {
    flex: 1;
    display: flex;
    min-height: 0;
    padding: 20px;
    flex-direction: column;
    font-size: 14px;
    color: #333;
    background: rgba(255, 255, 255);
  }
</style>
