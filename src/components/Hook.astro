---
// src/components/Hook.astro
interface Props {
  x: number; /* 起始列坐标 */
  y: number; /* 起始行坐标 */
  cols?: number; /* 占用几列 */
  rows?: number; /* 占用几行 */
}

const { x, y, cols = 4, rows = 3 } = Astro.props;
---

<div
  class="hook"
  style={`--x: ${x}; --y: ${y}; --cols: ${cols}; --rows: ${rows};`}
>
  <div class="peg-pin"></div>
  <!-- 模拟固定钉子 -->
  <slot />
</div>

<style>
  .hook {
    grid-column: var(--x) / span var(--cols);
    grid-row: var(--y) / span var(--rows);

    transform: translate(-50%, -6px);
    display: flex;
    position: relative;
    align-items: center;
  }

  .peg-pin {
    position: absolute;
    top: 0;
    left: 0;
    width: 12px;
    height: 12px;
    background: radial-gradient(circle at 30% 30%, #666, #111);
    border-radius: 50%;
    left: 50%;
    transform: translate(-50%, 0%);
    z-index: 20;
    box-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
  }

  @container (max-width: 640px) {
    .hook {
      /* 移动端：忽略 x, y，变为自动顺序排列 */
      grid-column: auto !important;
      grid-row: auto !important;
      width: 100%;
      height: auto;
      transform: none !important;
      display: block; /* 移动端改为块级，更易控制高度 */

      /* grid-column: span var(--cols); 
      grid-row: auto; */
      /* 如果在手机上想强制满宽，可以设为：grid-column: 1 / -1; */
    }
  }
</style>
