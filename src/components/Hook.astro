---
// src/components/Hook.astro
interface Props {
  x?: number; /* 起始列坐标 */
  y?: number; /* 起始行坐标 */
  cols?: number; /* 占用几列 */
  rows?: number; /* 占用几行 */
  class?: string; /* 可选的自定义类名 */
  style?: string;
}

const {
  x,
  y,
  cols = 4,
  rows = 3,
  class: customClass,
  style: incomingStyle = "",
} = Astro.props;

const combinedStyle = [
  `--x: ${x}`,
  `--y: ${y}`,
  `--cols: ${cols}`,
  `--rows: ${rows}`,
  incomingStyle, // 插入外部传入的 style (如 "display: none;")
]
  .filter(Boolean)
  .join("; ");
---

<div
  class:list={["hook", customClass]}
  data-orig-x={x}
  data-orig-y={y}
  data-orig-cols={cols}
  data-orig-rows={rows}
  style={combinedStyle}
>
  <div class="peg-pin"></div>
  <!-- 模拟固定钉子 -->
  <slot />
</div>

<style>
  .hook {
    grid-column: var(--x) / span var(--cols);
    grid-row: var(--y) / span var(--rows);
    display: flex;
    position: relative;
    align-items: flex-start;
    justify-content: center;
    /* padding-top: 10px; */
    box-sizing: border-box;
    margin-top: -6px;
  }
</style>
