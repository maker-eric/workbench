---
// src/components/Pegboard.astro
---

<div class="pegboard">
  <slot />
</div>

<style>
  .pegboard {
    display: grid;
    /* 自动填充列，宽度等于步进值 */
    grid-template-columns: repeat(auto-fill, var(--gap));
    grid-auto-rows: var(--gap);
    grid-auto-flow: dense;

    width: 100%;
    max-width: 1200px;

    background-image: radial-gradient(
      circle var(--hole-size) at center,
      var(--hole-color) 100%,
      transparent 100%
    );
    background-size: var(--gap) var(--gap);
    background-color: var(--board-bg);
    background-repeat: repeat;

    border: 2px solid #333;
    box-shadow: 10px 10px 0px #1a1a1a;
    padding: calc(var(--gap) / 2);
    position: relative;
  }
  @container (max-width: 640px) {
    .pegboard {
      /* 移动端改为单栏或双栏自动布局 */
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
      gap: var(--gap);
      background-size: var(--gap) var(--gap);
      overflow-y: auto;
    }
  }
</style>
