---
// src/components/Tool.astro
interface Props {
  label: string;
}
const { label } = Astro.props;
---

<div class="tool-wrapper acrylic-panel">
  <div class="tool-body">
    <slot />
  </div>
  <div class="tag">{label}</div>
</div>

<style>
  .tool-wrapper {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;

    overflow: hidden;
  }
  .tool-body {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 0;
    width: 100%;
    margin-top: 5px;
    font-size: 2rem;
    position: relative;
  }
  .tag {
    flex-shrink: 0;
    background: var(--accent);
    color: white;
    font-size: 10px;
    width: 100%;

    text-indent: 8px;

    padding: 4px 0; /* 稍微增加一点 padding */
    text-transform: uppercase;
    font-weight: bold;
    letter-spacing: 0.5px;
  }
</style>
